const express =
require("express");

const router =
express.Router();

const auth =
require("../middleware/auth");

const {
 addMenuItem,
 getMenuItems
}
=
require(
 "../controllers/menuController"
);

router.post(
 "/",
 auth,
 addMenuItem
);

router.get(
 "/:restaurantId",
 getMenuItems
);

module.exports =
router;